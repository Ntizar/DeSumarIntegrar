    50|.quiz-btn:hover{background:var(--azul-claro)}
    51|.quiz-btn.correct{background:var(--verde);color:#fff;border-color:var(--verde)}
    52|.quiz-btn.wrong{background:var(--rojo);color:#fff;border-color:var(--rojo)}
