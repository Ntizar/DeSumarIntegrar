    42|.summary{background:var(--azul-claro);border-radius:12px;padding:1.5rem;margin:2rem 0}
    43|.summary h3{color:var(--azul);margin-bottom:.8rem}
    44|.summary ul{list-style:none;padding:0}
    45|.summary li{padding:.3rem 0;padding-left:1.5rem;position:relative}
    46|.summary li::before{content:"✓";color:var(--verde);font-weight:bold;position:absolute;left:0}
    47|.footer{text-align:center;padding:2rem 1rem;color:var(--gris);font-size:.85rem;border-top:1px solid #e2e8f0;margin-top:2rem}
    48|.quiz-options{display:flex;gap:.5rem;justify-content:center;flex-wrap:wrap;margin:1rem 0}
