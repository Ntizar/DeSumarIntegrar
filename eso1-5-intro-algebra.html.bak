    16|.container{max-width:850px;margin:0 auto;padding:1.5rem}
    17|.chapter{margin-bottom:2.5rem}
    18|.chapter-title{font-size:1.4rem;color:var(--azul);margin-bottom:1rem;padding-bottom:.5rem;border-bottom:2px solid var(--azul-claro)}
