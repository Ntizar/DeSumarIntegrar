   163|<script>
   164|function newQuiz() {
   165|  const data = [{"q": "x + 5 = 12, x = ?", "opts": ["7", "17", "5"], "correct": 0}, {"q": "3x = 15, x = ?", "opts": ["5", "12", "18"], "correct": 0}, {"q": "2x + 3 = 11, x = ?", "opts": ["4", "7", "8"], "correct": 0}, {"q": "x - 4 = 9, x = ?", "opts": ["13", "5", "9"], "correct": 0}, {"q": "4x = 20, x = ?", "opts": ["5", "16", "24"], "correct": 0}];
   166|  const item = data[Math.floor(Math.random()*data.length)];
   167|  document.getElementById('eso1algDisplay').textContent = item.q;
   168|  const opts = item.opts;
   169|  const buttons = document.getElementById('eso1algButtons');
   170|  buttons.innerHTML = '';
   171|  opts.forEach((opt, i) => {
   172|    const btn = document.createElement('button');
   173|    btn.className = 'quiz-btn';
   174|    btn.textContent = opt;
   175|    btn.onclick = function() {
   176|      if(i === item.correct) {
   177|        this.classList.add('correct');
   178|        document.getElementById('interactiveResult').className = 'result ok';
   179|        document.getElementById('interactiveResult').textContent = '✅ ¡Correcto! ' + (item.explain || '');
   180|      } else {
   181|        this.classList.add('wrong');
   182|        document.getElementById('interactiveResult').className = 'result fail';
   183|        document.getElementById('interactiveResult').textContent = '❌ La respuesta es ' + opts[item.correct];
   184|      }
   185|    };
   186|    buttons.appendChild(btn);
   187|  });
   188|  document.getElementById('interactiveResult').textContent = '';
   189|}
   190|newQuiz();
   191|function checkExercise(btn, correct) {
   192|  const parent = btn.parentElement;
   193|  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
   194|  if(correct) { btn.classList.add('correct'); } else { btn.classList.add('wrong'); }
   195|}
   196|function checkVF(btn, correct) {
   197|  const parent = btn.parentElement;
   198|  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
   199|  if(correct) { btn.classList.add('correct'); btn.parentElement.parentElement.querySelector('p').textContent += ' ✅ ¡Correcto! 5x=25 → x=25÷5=5'; }
   200|  else { btn.classList.add('wrong'); btn.parentElement.parentElement.querySelector('p').textContent += ' ❌ ¡Era verdadero! 5x=25 → x=25÷5=5'; }
   201|}
   202|function checkInputEso1() {
   203|  const input = document.getElementById('eso1algInput');
   204|  const result = document.getElementById('eso1algInputResult');
   205|  const val = parseInt(input.value);
   206|  if(val === 17) {
   207|    result.className = 'result ok';
   208|    result.textContent = '✅ ¡Correcto! x = 10 + 7 = 17';
   209|  } else {
   210|    result.className = 'result fail';
   211|    result.textContent = '❌ x = 10 + 7 = 17. ¡Suma 7 a ambos lados!';
   212|  }
   213|}
   214|
   197|window.onscroll = function(){
   198|  var h = document.documentElement;
   199|  var p = (window.scrollY/(h.scrollHeight-h.clientHeight))*100;
   200|  document.getElementById('progress').style.width = p+'%';
   201|};
   202|</script>
