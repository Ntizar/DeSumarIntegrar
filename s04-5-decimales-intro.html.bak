</div>
</main>
<footer class="footer">
Hecho con ❤️ por David Antizar
</footer>

<script>

// --- Interactive decimal converter ---
function newDec() {
  const decs = [{d:'0,5',f:'5/10'},{d:'0,25',f:'25/100'},{d:'0,1',f:'1/10'},{d:'1,5',f:'15/10'},{d:'0,01',f:'1/100'},{d:'0,75',f:'75/100'}];
  const dec = decs[Math.floor(Math.random()*decs.length)];
  document.getElementById('decDisplay').textContent = '¿Qué fracción es ' + dec.d + '?';
  const opts = [dec.f, '1/2', '1/4', '1/10', '1/100', '2/5', '3/4'];
  const unique = [...new Set(opts)].filter(x => x !== dec.f);
  const wrongs = unique.sort(()=>Math.random()-0.5).slice(0,3);
  const allOpts = [dec.f, ...wrongs].sort(()=>Math.random()-0.5);
  const buttons = document.getElementById('decButtons');
  buttons.innerHTML = '';
  allOpts.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'quiz-btn';
    btn.textContent = opt;
    btn.onclick = function() {
      if(opt === dec.f) {
        this.classList.add('correct');
        document.getElementById('interactiveResult').className = 'result ok';
        document.getElementById('interactiveResult').textContent = '✅ ¡Correcto! ' + dec.d + ' = ' + dec.f;
      } else {
        this.classList.add('wrong');
        document.getElementById('interactiveResult').className = 'result fail';
        document.getElementById('interactiveResult').textContent = '❌ La respuesta es ' + dec.f;
      }
    };
    buttons.appendChild(btn);
  });
  document.getElementById('interactiveResult').textContent = '';
}
newDec();

// --- Exercise checkers ---
function checkExercise(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  if(correct) { btn.classList.add('correct'); } else { btn.classList.add('wrong'); }
}

function checkVF(btn, isCorrect, solId) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.vf-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  if(isCorrect) {
    btn.classList.add('correct');
  } else {
    btn.classList.add('wrong');
  }
  document.getElementById(solId).classList.add('show');
}

function checkE2() {
  const val = document.getElementById('e2a').value.trim();
  const sol = document.getElementById('solE2');
  if(val === '25') {
    sol.className = 'solution show';
    sol.style.background = 'var(--verde-claro)';
    sol.innerHTML = '✅ ¡Correcto! 0,25 = 25/100. Los dos ceros tras la coma nos dicen que el denominador es 100.';
  } else {
    sol.className = 'solution show';
    sol.style.background = 'var(--rojo-claro)';
    sol.innerHTML = '❌ La respuesta es 25. 0,25 tiene dos cifras tras la coma → denominador 100 → numerador 25.';
  }
}

function checkE3() {
  const val = document.getElementById('e3').value.trim();
  const sol = document.getElementById('solE3');
  if(val === '3') {
    sol.className = 'solution show';
    sol.style.background = 'var(--verde-claro)';
    sol.innerHTML = '✅ ¡Correcto! 0,3 = 3/10. Una cifra tras la coma = décimas = /10.';
  } else {
    sol.className = 'solution show';
    sol.style.background = 'var(--rojo-claro)';
    sol.innerHTML = '❌ La respuesta es 3. 0,3 tiene una cifra tras la coma → denominador 10 → numerador 3.';
  }
}

function checkE6() {
  const val = document.getElementById('e6').value.trim().replace(/\s/g, '');
  // Accept various orderings that are mathematically correct
  const sol = document.getElementById('solE6');
  // Normalize: accept both comma and period
  const normalized = val.replace(/\./g, ',');
  const correctPatterns = [
    '0,05;0,15;0,5;0,50',
    '0,05;0,15;0,50;0,5',
    '0,05,0,15,0,5,0,50',
    '0,05,0,15,0,50,0,5'
  ];
  if (correctPatterns.includes(normalized)) {
    sol.className = 'solution show';
    sol.style.background = 'var(--verde-claro)';
    sol.innerHTML = '✅ ¡Correcto! Orden: 0,05 &lt; 0,15 &lt; 0,5 = 0,50.';
  } else {
    sol.className = 'solution show';
    sol.style.background = 'var(--rojo-claro)';
    sol.innerHTML = '❌ El orden correcto es: 0,05 &lt; 0,15 &lt; 0,5 = 0,50. Recuerda: 0,5 = 0,50.';
  }
}

function checkE7() {
  const sol = document.getElementById('solE7');
  sol.className = 'solution show';
  sol.style.background = 'var(--verde-claro)';
  sol.innerHTML = '✅ 0,75 + 0,25 = 1,00 km. ¡Pablo corre exactamente 1 kilómetro al día! 🏁';
}

// --- Progress bar ---
window.onscroll = function(){
  var h = document.documentElement;
  var p = (window.scrollY/(h.scrollHeight-h.clientHeight))*100;
  document.getElementById('progress').style.width = p+'%';
};
</script>
</body>
</html>
