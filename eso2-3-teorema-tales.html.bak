</footer>
<script>
function newQuiz() {
  const data = [{"q": "a=6, b=3, c=8, d=?", "opts": ["4", "16", "2"], "correct": 0}, {"q": "a=10, b=5, c=12, d=?", "opts": ["6", "24", "3"], "correct": 0}, {"q": "a=4, b=2, c=9, d=?", "opts": ["4.5", "18", "2"], "correct": 0}, {"q": "a=8, b=4, c=15, d=?", "opts": ["7.5", "30", "5"], "correct": 0}, {"q": "a=12, b=6, c=20, d=?", "opts": ["10", "40", "5"], "correct": 0}];
  const item = data[Math.floor(Math.random()*data.length)];
  document.getElementById('eso2talesDisplay').textContent = item.q;
  const opts = item.opts;
  const buttons = document.getElementById('eso2talesButtons');
  buttons.innerHTML = '';
  opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-btn';
    btn.textContent = opt;
    btn.onclick = function() {
      if(i === item.correct) {
        this.classList.add('correct');
        document.getElementById('interactiveResult').className = 'result ok';
        document.getElementById('interactiveResult').textContent = '✅ ¡Correcto! ' + (item.explain || '');
      } else {
        this.classList.add('wrong');
        document.getElementById('interactiveResult').className = 'result fail';
        document.getElementById('interactiveResult').textContent = '❌ La respuesta es ' + opts[item.correct];
      }
    };
    buttons.appendChild(btn);
  });
  document.getElementById('interactiveResult').textContent = '';
}
newQuiz();
function checkExercise(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  if(correct) { btn.classList.add('correct'); } else { btn.classList.add('wrong'); }
}
function checkTalesInput1() {
  const input = document.getElementById('tales-input-1');
  const fb = document.getElementById('tales-fb-1');
  if (!input || !fb) return;
  const val = parseFloat(input.value);
  if (val === 7.5) {
    fb.className = 'result ok';
    fb.textContent = '✅ ¡Correcto! d = b×c/a = 4×15/4 = 7.5';
  } else {
    fb.className = 'result fail';
    fb.textContent = '❌ Incorrecto. d = b×c/a = 4×15/4 = 7.5';
  }
}
function checkVF(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  const fb = document.getElementById('tales-vf-result');
  if(correct) {
    btn.classList.add('correct');
    fb.className = 'result ok';
    fb.textContent = '✅ ¡Verdadero! 12/6 = 20/10 = 2. ¡Proporcionalidad!';
  } else {
    btn.classList.add('wrong');
    fb.className = 'result fail';
    fb.textContent = '❌ Falso. 12/6 = 2 y 20/10 = 2, ¡son iguales!';
  }
}
window.onscroll = function(){
  var h = document.documentElement;
  var p = (window.scrollY/(h.scrollHeight-h.clientHeight))*100;
  document.getElementById('progress').style.width = p+'%';
};
</script>
</body>
