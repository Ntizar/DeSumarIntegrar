</div>
</div>
<div class="footer">Hecho con ❤️ por David Antizar</div>

<script>
window.addEventListener('scroll', () => {
  const winScroll = document.documentElement.scrollTop;
  const height = document.documentElement.scrollHeight - document.documentElement.clientHeight;
  const scrolled = (winScroll / height) * 100;
  document.getElementById('progress').style.width = scrolled + '%';
});

document.addEventListener('DOMContentLoaded', () => {
  renderMathInElement(document.body, {
    delimiters: [
      {left: '$$', right: '$$', display: true},
      {left: '$', right: '$', display: false}
    ],
    throwOnError: false
  });

function checkExercise(num, correct) {
  const input = document.getElementById('e' + num);
  const feedback = document.getElementById('e' + num + '-fb');
  if (!input || !feedback) return;
  const value = parseFloat(input.value);
  if (isNaN(value)) { feedback.textContent = 'Introduce un número'; feedback.className = 'feedback incorrect'; return; }
  if (Math.abs(value - correct) < 0.01) { feedback.textContent = '¡Correcto! 🎉'; feedback.className = 'feedback correct'; }
  else { feedback.textContent = 'Incorrecto. La respuesta es ' + correct; feedback.className = 'feedback incorrect'; }
}

function checkE1() {
  const val = parseFloat(document.getElementById('e1').value);
  const fb = document.getElementById('e1-fb');
  if (Math.abs(val - 2) < 0.01) { fb.textContent = '✅ ¡Correcto! f'(x) = 2x-4 = 0 → x = 2'; fb.className = 'feedback correct'; }
  else { fb.textContent = '❌ f'(x) = 2x - 4 = 0 → x = 2. El mínimo está en x = 2.'; fb.className = 'feedback incorrect'; }
}

function checkVF(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  const fb = document.getElementById('e2-fb');
  if (correct) { btn.classList.add('correct'); fb.textContent = '✅ ¡Verdadero! f'' < 0 significa cóncava hacia abajo → máximo.'; fb.className = 'feedback correct'; }
  else { btn.classList.add('wrong'); fb.textContent = '❌ Falso. f'' < 0 → cóncava hacia abajo → ¡es un máximo!'; fb.className = 'feedback incorrect'; }
}

function moveStep(el) {
  const container = document.getElementById('ordenContainer');
  const steps = Array.from(container.querySelectorAll('.step'));
  const idx = steps.indexOf(el);
  if (idx > 0) { container.insertBefore(el, steps[idx-1]); }
  else if (idx < steps.length - 1) { container.insertBefore(el, steps[idx+2]); }
}

function checkOrden() {
  const steps = document.getElementById('ordenContainer').querySelectorAll('.step');
  let correct = true;
  steps.forEach((s, i) => { if (parseInt(s.dataset.pos) !== i + 1) correct = false; });
  const fb = document.getElementById('e3-fb');
  if (correct) { fb.textContent = '✅ ¡Orden correcto! ①Derivar → ②Encontrar puntos críticos → ③Evaluar f'''; fb.className = 'feedback correct'; }
  else { fb.textContent = '❌ Orden incorrecto. Primero derivas, luego encuentras puntos críticos, luego evalúas f''.'; fb.className = 'feedback incorrect'; }
}

function checkQuiz4(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  const fb = document.getElementById('e4-fb');
  if (correct) { btn.classList.add('correct'); fb.textContent = '✅ ¡Correcto! f'(x) = 3x²-6x = 3x(x-2) = 0 → x=0, x=2'; fb.className = 'feedback correct'; }
  else { btn.classList.add('wrong'); fb.textContent = '❌ f'(x) = 3x² - 6x = 3x(x-2). Puntos críticos: x=0 y x=2.'; fb.className = 'feedback incorrect'; }
}

function checkQuiz5(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  const fb = document.getElementById('e5-fb');
  if (correct) { btn.classList.add('correct'); fb.textContent = '✅ ¡Correcto! C'(x) = 2x-10 = 0 → x = 5. Mínimo coste a 5 unidades.'; fb.className = 'feedback correct'; }
  else { btn.classList.add('wrong'); fb.textContent = '❌ C'(x) = 2x - 10 = 0 → x = 5. Mínimo a 5 unidades.'; fb.className = 'feedback incorrect'; }
}

function checkQuiz6(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  const fb = document.getElementById('e6-fb');
  if (correct) { btn.classList.add('correct'); fb.textContent = '✅ ¡Correcto! f''(3) = -5 < 0 → cóncava abajo → máximo.'; fb.className = 'feedback correct'; }
  else { btn.classList.add('wrong'); fb.textContent = '❌ f''(3) = -5 < 0 → cóncava hacia abajo → ¡es un máximo!'; fb.className = 'feedback incorrect'; }
}

function updatePlot() {
  const a = parseFloat(document.getElementById('paramA').value);
  const b = parseFloat(document.getElementById('paramB').value);
  const c = parseFloat(document.getElementById('paramC').value);
  const d = parseFloat(document.getElementById('paramD').value);
  document.getElementById('valA').textContent = a;
  document.getElementById('valB').textContent = b;
  document.getElementById('valC').textContent = c;
  document.getElementById('valD').textContent = d;

  const x = [];
  const y = [];
  const yp = [];
  for (let i = -10; i <= 10; i += 0.5) {
    x.push(i);
    y.push(a*i*i*i + b*i*i + c*i + d);
    yp.push(3*a*i*i + 2*b*i + c);
  }

  const traces = [
    {x, y, type: 'scatter', mode: 'lines', name: 'f(x)', line: {color: '#2563eb', width: 2}},
    {x, y: yp, type: 'scatter', mode: 'lines', name: "f'(x)", line: {color: '#f97316', width: 2, dash: 'dash'}}
  ];

  const layout = {
    title: 'Función (azul) y derivada (naranja)',
    xaxis: {title: 'x', range: [-10, 10]},
    yaxis: {title: 'y'},
    showlegend: true,
    margin: {t: 40, r: 20, l: 50, b: 40}
  };

  Plotly.react('interactivePlot', traces, layout);

  // Find critical points
  if (Math.abs(a) > 0.001) {
    const disc = 4*b*b - 12*a*c;
    if (disc >= 0) {
      const x1 = (-2*b + Math.sqrt(disc)) / (6*a);
      const x2 = (-2*b - Math.sqrt(disc)) / (6*a);
      const f1 = a*x1*x1*x1 + b*x1*x1 + c*x1 + d;
      const f2 = a*x2*x2*x2 + b*x2*x2 + c*x2 + d;
      document.getElementById('interactiveInfo').innerHTML =
        '<b>Puntos críticos:</b> x₁ = ' + x1.toFixed(2) + ' (f=' + f1.toFixed(2) + '), x₂ = ' + x2.toFixed(2) + ' (f=' + f2.toFixed(2) + ')<br>' +
        '<b>f''(x₁):</b> ' + (6*a*x1 + 2*b).toFixed(2) + ' → ' + ((6*a*x1 + 2*b) < 0 ? 'MÁXIMO' : 'MÍNIMO') + '<br>' +
        '<b>f''(x₂):</b> ' + (6*a*x2 + 2*b).toFixed(2) + ' → ' + ((6*a*x2 + 2*b) < 0 ? 'MÁXIMO' : 'MÍNIMO');
    } else {
      document.getElementById('interactiveInfo').innerHTML = '<b>Sin puntos críticos reales</b> (discriminante < 0)';
    }
  } else if (Math.abs(b) > 0.001) {
    const xc = -c / (2*b);
    document.getElementById('interactiveInfo').innerHTML = '<b>Punto crítico:</b> x = ' + xc.toFixed(2);
  } else {
    document.getElementById('interactiveInfo').innerHTML = '<b>Sin puntos críticos</b> (función lineal)';
  }
}

function checkExercise(num, correct) {
  const input = document.getElementById('e' + num);
  const feedback = document.getElementById('e' + num + '-fb');
  if (!input || !feedback) return;
  const value = parseFloat(input.value);
  if (isNaN(value)) { feedback.textContent = 'Introduce un número'; feedback.className = 'feedback incorrect'; return; }
  if (Math.abs(value - correct) < 0.01) { feedback.textContent = '¡Correcto! 🎉'; feedback.className = 'feedback correct'; }
  else { feedback.textContent = 'Incorrecto. La respuesta es ' + correct; feedback.className = 'feedback incorrect'; }
}

// Init interactive plot
updatePlot();
});
</script>
</body>
</html>