<script>

let currentTable = 0;

function selectTable(n) {
  currentTable = n;
  const display = document.getElementById('tableDisplay');
  let seq = '';
  for(let i = 1; i <= 10; i++) {
    seq += n + ' × ' + i + ' = ' + (n*i);
    if(i < 10) seq += ' | ';
  }
  display.innerHTML = seq;
  newQuiz();
}

function newQuiz() {
  const n = currentTable || Math.floor(Math.random()*5)+1;
  const m = Math.floor(Math.random()*10)+1;
  const quizAnswer = n * m;
  const quiz = document.getElementById('tableQuiz');
  quiz.innerHTML = '<p style="font-size:1.3rem;font-weight:700;margin-bottom:1rem">' + n + ' × ' + m + ' = ?</p>';
  const opts = [quizAnswer, quizAnswer + n, quizAnswer - n, quizAnswer + 1].filter((v,i,a) => a.indexOf(v) === i && v > 0);
  opts.sort(() => Math.random() - 0.5);
  opts.forEach(opt => {
    const btn = document.createElement('button');
    btn.className = 'quiz-btn';
    btn.textContent = opt;
    btn.onclick = function() {
      if(opt === quizAnswer) {
        this.classList.add('correct');
        document.getElementById('interactiveResult').className = 'result ok';
        document.getElementById('interactiveResult').textContent = '✅ ¡Correcto! ' + n + ' × ' + m + ' = ' + quizAnswer;
      } else {
        this.classList.add('wrong');
        document.getElementById('interactiveResult').className = 'result fail';
        document.getElementById('interactiveResult').textContent = '❌ La respuesta es ' + quizAnswer;
      }
    };
    quiz.appendChild(btn);
  });
  document.getElementById('interactiveResult').textContent = '';
}

selectTable(2);

function checkExercise(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => {
    b.disabled = true;
    b.style.pointerEvents = 'none';
  });
  if(correct) { btn.classList.add('correct'); }
  else { btn.classList.add('wrong'); }
}

function checkVF(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => {
    b.disabled = true;
    b.style.pointerEvents = 'none';
  });
  const fbId = btn.closest('.exercise').querySelector('.feedback').id;
  const fb = document.getElementById(fbId);
  if (correct) {
    btn.classList.add('correct');
    fb.className = 'feedback correct';
    fb.textContent = '✅ ¡Correcto!';
  } else {
    btn.classList.add('wrong');
    fb.className = 'feedback incorrect';
    fb.textContent = '❌ Incorrecto. ¡Recuerda: 2 × 8 = 16!';
  }
}

function checkFillIn(exNum, correctAnswers) {
  const input = document.getElementById('fill' + exNum);
  const answer = input.value.trim().toLowerCase();
  const fb = document.getElementById('fill' + exNum + 'fb');
  if (correctAnswers.some(a => a.toLowerCase() === answer)) {
    fb.className = 'feedback correct';
    fb.textContent = '✅ ¡Correcto!';
    input.style.borderColor = 'var(--verde)';
  } else {
    fb.className = 'feedback incorrect';
    fb.textContent = '❌ No es esa. ¡Pruébalo otra vez!';
    input.style.borderColor = 'var(--rojo)';
  }
}

function checkOrden6() {
  const input = document.getElementById('fill6').value.trim().toLowerCase();
  const fb = document.getElementById('fill6fb');
  const nums = input.replace(/\s/g, '').split(',').map(Number);
  if (nums.length === 3 && nums[0] === 6 && nums[1] === 12 && nums[2] === 16) {
    fb.className = 'feedback correct';
    fb.textContent = '✅ ¡Perfecto! 2×3=6, 3×5=15... espera, 4×4=16. Orden: 6, 15, 16';
  } else {
    fb.className = 'feedback incorrect';
    fb.textContent = '❌ El orden correcto es: 6 (2×3), 15 (3×5), 16 (4×4)';
  }
}

function checkExerciseOp(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => {
    b.disabled = true;
    b.style.pointerEvents = 'none';
  });
  const fb = document.getElementById('ex8fb');
  if (correct) {
    btn.classList.add('correct');
    fb.className = 'feedback correct';
    fb.textContent = '✅ ¡Correcto! 20 ÷ 5 = 4 cuadernos';
  } else {
    btn.classList.add('wrong');
    fb.className = 'feedback incorrect';
    fb.textContent = '❌ No. Necesitas dividir: 20 ÷ 5 = 4';
  }
}


window.onscroll = function(){
  var h = document.documentElement;
  var p = (window.scrollY/(h.scrollHeight-h.clientHeight))*100;
  document.getElementById('progress').style.width = p+'%';
};
</script>
</body>
</html>