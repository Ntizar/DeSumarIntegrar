</footer>
<script>
function newQuiz() {
  const data = [{"q": "P(sacar 5 en dado):", "opts": ["1/6", "1/5", "1/4"], "correct": 0}, {"q": "P(sacar cara en moneda):", "opts": ["1/2", "1/3", "1/4"], "correct": 0}, {"q": "P(sacar par en dado):", "opts": ["1/2", "1/3", "1/6"], "correct": 0}, {"q": "P(no sacar 6 en dado):", "opts": ["5/6", "1/6", "6/6"], "correct": 0}, {"q": "P(sacar rey en baraja 40):", "opts": ["4/40", "10/40", "1/40"], "correct": 0}];
  const item = data[Math.floor(Math.random()*data.length)];
  document.getElementById('eso2probDisplay').textContent = item.q;
  const opts = item.opts;
  const buttons = document.getElementById('eso2probButtons');
  buttons.innerHTML = '';
  opts.forEach((opt, i) => {
    const btn = document.createElement('button');
    btn.className = 'quiz-btn';
    btn.textContent = opt;
    btn.onclick = function() {
      if(i === item.correct) {
        this.classList.add('correct');
        document.getElementById('interactiveResult').className = 'result ok';
        document.getElementById('interactiveResult').textContent = '✅ ¡Correcto! ' + (item.explain || '');
      } else {
        this.classList.add('wrong');
        document.getElementById('interactiveResult').className = 'result fail';
        document.getElementById('interactiveResult').textContent = '❌ La respuesta es ' + opts[item.correct];
      }
    };
    buttons.appendChild(btn);
  });
  document.getElementById('interactiveResult').textContent = '';
}
newQuiz();

function checkExercise(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  if(correct) { btn.classList.add('correct'); } else { btn.classList.add('wrong'); }
}

function checkVF(btn, correct) {
  const parent = btn.parentElement;
  parent.querySelectorAll('.quiz-btn').forEach(b => { b.disabled = true; b.style.pointerEvents = 'none'; });
  if(correct) { btn.classList.add('correct'); } else { btn.classList.add('wrong'); }
}

function checkFillIn(exNum, correctAnswers) {
  const input = document.getElementById('eso2fi' + exNum);
  const fb = document.getElementById('eso2fi' + exNum + '-fb');
  if (!input || !fb) return;
  const val = input.value.trim().toLowerCase();
  if (!val) { fb.textContent = 'Escribe un número'; fb.className = 'feedback incorrect'; return; }
  if (correctAnswers.some(a => a.toLowerCase() === val)) {
    fb.textContent = '✅ ¡Correcto!'; fb.className = 'feedback correct';
  } else {
    fb.textContent = '❌ Incorrecto. La respuesta es: ' + correctAnswers[0];
    fb.className = 'feedback incorrect';
  }
}

window.onscroll = function(){
  var h = document.documentElement;
  var p = (window.scrollY/(h.scrollHeight-h.clientHeight))*100;
  document.getElementById('progress').style.width = p+'%';
};
</script>
</body>
</html>
